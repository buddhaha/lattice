---
import Layout from '../../layouts/Layout.astro';
import { readSortedContentDir } from '../../lib/content';
import { renderMarkdown } from '../../lib/markdown';

export function getStaticPaths() {
  return readSortedContentDir('articles', 'ARTICLE').map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const renderedBody = renderMarkdown(article.body || '');
---

<Layout title={`${article.title} — Mirek`}>
  <main class="article-page">
    <div class="article-page-inner">
      <a class="article-back" href={`${import.meta.env.BASE_URL}`}>← Back to Lattice</a>
      <div class="article-page-meta">
        <span class="article-page-type">Article</span>
        <span class="article-page-date">{article.date}</span>
      </div>
      <h1>{article.title}</h1>
      <article class="article-page-body markdown-body" set:html={renderedBody}></article>
    </div>
  </main>
</Layout>

<style>
  :global(html),
  :global(body) {
    height: auto;
    overflow: auto;
  }
  .article-page {
    min-height: 100vh;
    background:
      radial-gradient(ellipse at top left, rgba(64,200,240,0.08) 0%, transparent 45%),
      radial-gradient(ellipse at bottom right, rgba(0,232,143,0.05) 0%, transparent 40%),
      var(--bg-void);
    padding: 48px 24px 72px;
  }
  .article-page-inner {
    max-width: 1080px;
    margin: 0 auto;
    padding: 28px 32px 40px;
    background: rgba(10,10,15,0.82);
    border: 1px solid var(--border);
    box-shadow: 0 18px 80px rgba(0,0,0,0.35);
  }
  .article-back {
    display: inline-block;
    margin-bottom: 22px;
    color: var(--cyan);
    text-decoration: none;
    font-size: 16px;
  }
  .article-page-meta {
    display: flex;
    gap: 12px;
    align-items: center;
    margin-bottom: 18px;
    color: var(--text-dim);
  }
  .article-page-type {
    color: var(--cyan);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-size: 14px;
  }
  .article-page-date {
    font-size: 16px;
  }
  .article-page h1 {
    font-family: var(--display);
    color: #fff;
    font-size: 42px;
    line-height: 1.1;
    margin-bottom: 26px;
  }
  @media (max-width: 860px) {
    .article-page {
      padding: 20px 12px 36px;
    }
    .article-page-inner {
      padding: 22px 18px 28px;
    }
    .article-page h1 {
      font-size: 30px;
    }
  }
</style>
